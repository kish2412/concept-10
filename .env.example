# Human-friendly app label used in API metadata.
APP_NAME=Concept 10 API

# Runtime environment name: development, staging, or production.
ENVIRONMENT=development

# FastAPI API prefix.
API_V1_PREFIX=/api/v1

# Async SQLAlchemy database connection string.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinic_saas

# JWT signing secret.
SECRET_KEY=replace_with_secure_random_string

# JWT algorithm.
ALGORITHM=HS256

# Access token TTL in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backend log level.
LOG_LEVEL=INFO

# Set to true to log successful tenant auth checks in middleware.
TENANT_AUTH_LOG_SUCCESS=false

# Global switch for all AI/agentic workflows.
AGENTIC_ENABLED=true

# Concept10 agentic specialist service URL (triage summary agent).
AGENTIC_SERVICE_BASE_URL=http://localhost:8001

# Service-to-service bearer token used by OMS backend to call concept10-agentic.
AGENTIC_SERVICE_TOKEN=replace_with_local_service_token

# Role header forwarded to specialist API auth guard.
AGENTIC_SERVICE_ROLE=nurse

# HTTP timeout (seconds) for specialist agent calls.
AGENTIC_SERVICE_TIMEOUT_SECONDS=20

# Metadata tags used in agentic summary responses.
LLM_PROVIDER=none
LLM_MODEL=none

# Optional OpenAI provider settings for model-backed agent execution.
# Set LLM_PROVIDER=openai and LLM_MODEL to a supported model when enabled.
OPENAI_API_KEY=replace_with_openai_key
# Optional custom endpoint (Azure/OpenAI-compatible gateway).
OPENAI_BASE_URL=

# JSON array of allowed frontend origins for CORS.
FRONTEND_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]


CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=whsec_xxx   (get from Clerk dashboard → Webhooks)