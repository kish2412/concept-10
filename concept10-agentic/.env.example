# Application
APP_ENV=local
SERVICE_VERSION=0.1.0
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Agent orchestration
AGENT_REGISTRY_PATH=agents/registry/agent_registry.yaml
DEFAULT_AGENT_PROVIDER=
DEFAULT_AGENT_MODEL=
MAX_PARALLEL_AGENT_TASKS=8
ORCHESTRATION_TIMEOUT_SECONDS=60

# Prompt rendering
PROMPT_TEMPLATE_DIR=core/prompts

# Context management
CONTEXT_BACKEND=memory
CONTEXT_REDIS_URL=redis://localhost:6379/0
CONTEXT_DEFAULT_MAX_TOKENS=8192

# Governance / guardrails
ENABLE_GOVERNANCE_VALIDATION=true
GOVERNANCE_FAIL_CLOSED=true

# Observability
ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_ENDPOINT=

# LangSmith / LangChain tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=agent-orchestration-framework

ENABLE_OTEL=false
OTEL_SERVICE_NAME=agent-orchestration-framework
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Frontend dashboard (Vite)
DASHBOARD_PORT=5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
