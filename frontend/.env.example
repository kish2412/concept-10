# Clerk public key used by the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Clerk secret used by Next.js server runtime only.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Auth routes.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/patients
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/select-clinic

# Backend API base URL used by the frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
